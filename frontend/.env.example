# ════════════════════════════════════════════════════════════════════════════════
# SOUNDLOG Frontend - Variables de Entorno
#
# IMPORTANTE:
# 1. Copiar a .env.local para desarrollo local
# 2. NUNCA commitear con valores reales
# 3. En CI/CD los valores se inyectan automáticamente
# ════════════════════════════════════════════════════════════════════════════════

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🌐 API
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# URL base del API backend
# Desarrollo: http://localhost:8000
# Producción: https://api.soundlog.example.com
VITE_API_BASE_URL=http://localhost:8000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🎯 APLICACIÓN
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Nombre de la aplicación
VITE_APP_NAME=Soundlog

# Versión de la aplicación
VITE_APP_VERSION=1.0.0

# ════════════════════════════════════════════════════════════════════════════════
# 📌 DESARROLLO
# ════════════════════════════════════════════════════════════════════════════════
#
# Para desarrollo local, copiar a .env.local con estos valores:
#
# VITE_API_BASE_URL=http://localhost:8000
# VITE_APP_NAME=Soundlog
# VITE_APP_VERSION=1.0.0-dev
#
# ════════════════════════════════════════════════════════════════════════════════
# 🚀 PRODUCCIÓN
# ════════════════════════════════════════════════════════════════════════════════
#
# En CI/CD (GitHub Actions), inyectar automáticamente:
#
# VITE_API_BASE_URL=https://api.soundlog.com
# VITE_APP_NAME=Soundlog
# VITE_APP_VERSION=${{ github.ref_name }}
#
# ════════════════════════════════════════════════════════════════════════════════
